parameters:
    level: 1 # TODO: raise level incrementally as codebase is cleaned up
    
    # Target PHP 7.4 specifically to match the plugin's platform requirement
    phpVersion: 70400
    
    # Store the result cache inside the project folder for easy CI cache restoration
    tmpDir: tmp/phpstan
    
    # Force evaluation of actual runtime types over potentially outdated PHPDoc types
    treatPhpDocTypesAsCertain: false

    paths:
        - admin
        - includes
        - public
        - index.php
        - uninstall.php
        - wpfaevent.php

    # Silencing legacy/backup files that are out of scope for the current cleanup PR.
    # We use 'analyseAndScan' because these files have no connections to the active
    # codebase and should be completely hidden from PHPStan until they are refactored.
    # TODO: Remove individual file exclusions below as they are refactored into the core codebase.
    excludePaths:
        analyseAndScan:
            - admin/partials/admin-dashboard.php
            - admin/partials/wpfaevent-admin-display.php
            - includes/class-wpfaevent-landing.php
            - includes/class-wpfaevent-uninstaller.php
            - public/partials/schedule-page.php
            - public/partials/wpfaevent-landing-template.php

    # IMPORTANT: phpstan/extension-installer auto-loads installed PHPStan extensions
    # and rulesets that expose `extra.phpstan.includes`. php-stubs/wp-cli-stubs is
    # a raw PHP stub repository and does not expose PHPStan include metadata, so we
    # must explicitly point PHPStan here to discover global classes like WP_CLI.
    scanFiles:
        - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
        - vendor/php-stubs/wp-cli-stubs/wp-cli-commands-stubs.php

    # Loads custom global constants (like WPFAEVENT_PATH) before running analysis
    bootstrapFiles:
        - phpstan-bootstrap.php
