{
    "name": "fossasia/wpfaevent",
    "description": "WPFA Event WordPress plugin",
    "type": "wordpress-plugin",
    "license": "Apache-2.0",

    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-stubs/wp-cli-stubs": "^2.12",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.13",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.3",
        "yoast/phpunit-polyfills": "^2.0"
    },

    "scripts": {
        "phpcbf": "phpcbf",
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse --memory-limit=2048M",
        "setup-tests": "bash bin/install-wp-tests.sh wordpress_test ${WP_DB_USER:-wp_test} ${WP_DB_PASS:-test_password} ${WP_DB_HOST:-127.0.0.1}",
        "test": "vendor/bin/phpunit"
    },

    "scripts-descriptions": {
        "phpcbf": "Run PHP Code Beautifier to fix coding standards",
        "phpcs": "Run PHP_CodeSniffer to check coding standards",
        "phpstan": "Run PHPStan static analysis for PHP code quality",
        "setup-tests": "Bootstrap the WordPress test environment (requires WP_DB_USER and WP_DB_PASS env vars)",
        "test": "Run PHPUnit regression test suite"
    },

    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
